{
  "name": "@deusexlumen/agents-hub",
  "version": "3.1.0",
  "description": "Dynamic Multi-Agent Orchestration System with State Persistence, Smart Context Loading, MCP Integration, and Resilient Operations",
  "main": "index.js",
  "bin": {
    "agents-hub": "./bin/agents-hub.js"
  },
  "scripts": {
    "start": "node bin/agents-hub.js",
    "master": "node bin/agents-hub.js",
    "test": "cd core && node state-persistence.test.js && node template-loader.test.js && node smart-loader.test.js && node resilient-ops.test.js",
    "test:resilient": "cd core && node resilient-ops.test.js",
    "validate": "node core/workflow-validator.js",
    "cli": "node bin/agents-hub.js",
    "init": "node bin/agents-hub.js init",
    "status": "node bin/agents-hub.js status",
    "health": "node -e \"const { healthMonitor } = require('./core/health-check'); healthMonitor.runChecks().then(s => console.log(JSON.stringify(s, null, 2)));\"",
    "cleanup": "node -e \"const { StateManager } = require('./core/state-persistence'); new StateManager().cleanup();\""
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "workflow",
    "state-management",
    "multi-agent",
    "automation",
    "mcp"
  ],
  "author": "Deus Ex Lumen <deus@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deusexlumen/agents-hub.git"
  },
  "bugs": {
    "url": "https://github.com/deusexlumen/agents-hub/issues"
  },
  "homepage": "https://github.com/deusexlumen/agents-hub#readme",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "execa": "^9.6.1",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0",
    "xstate": "^5.28.0",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "index.js",
    "bin/",
    "core/",
    "templates/",
    "workflows/",
    "phases/",
    "AGENTS-AUTONOMOUS.md",
    "learning_data/",
    "README.md",
    "LICENSE"
  ]
}
